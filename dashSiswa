/**
 * 🛠️ HELPER ENGINE: GOOGLE DRIVE DIRECT LINK CONVERTER
 * Mengubah link preview 'view' Google Drive menjadi Direct URL Gambar bypass Sandbox
 * =========================================================================
 */
function ubahKeDirectLinkDrive(urlMentah) {
  if (!urlMentah || typeof urlMentah !== 'string') return 'https://placehold.co/150x200?text=Tanpa+Foto';
  
  // Deteksi ID File unik dari pola URL Google Drive standard
  var match = urlMentah.match(/\/d\/([a-zA-Z0-9_-]+)/) || urlMentah.match(/id=([a-zA-Z0-9_-]+)/);
  
  if (match && match[1]) {
    var idFile = match[1];
    // Menggunakan endpoint lh3 yang super lancar dan anti-block di dalam Apps Script
    return 'https://lh3.googleusercontent.com/u/0/d/' + idFile;
  }
  
  // Jika link bukan dari Drive (misal hosting luar), biarkan apa adanya
  return urlMentah;
}

// 🌟 FUNGSI EMIT DROPDOWN UTUH: Kunci presisi ke ID 'selSekolahAlternatif' & Master Server
function muatOpsiPilihanSekolahSiswa() {
  var sel = document.getElementById('selSekolahAlternatif');
  var btn = document.getElementById('btnRefreshAlternatif');
  var icon = document.getElementById('iconRefreshAlternatif');
  var spinner = document.getElementById('spinnerRefreshAlternatif');
  
  if (!sel) {
    console.error("❌ EROR ELEMEN: ID 'selSekolahAlternatif' tidak ditemukan di HTML.");
    return;
  }

  console.log("-> Tombol Reload dipicu. Menghubungkan ke server pusat...");

  // 1. Set status loading (kunci tombol agar tidak di-klik double)
  sel.innerHTML = '<option value="" disabled selected>⏳ Memuat pilihan sekolah alternatif...</option>';
  if (btn) btn.disabled = true;
  if (icon) icon.classList.add('d-none');
  if (spinner) spinner.classList.remove('d-none');

  // 2. Jalankan penembakan data ke server Apps Script secara lurus & bersih
  if (typeof google !== 'undefined' && google.script && google.script.run) {
    google.script.run
      .withSuccessHandler(function(res) {
        console.log("-> Respon sukses dari server diterima:", res);
        
        // Kembalikan tombol ke kondisi normal
        if (btn) btn.disabled = false;
        if (icon) icon.classList.remove('d-none');
        if (spinner) spinner.classList.add('d-none');
        
        sel.innerHTML = '<option value="" disabled selected>-- Pilih Sekolah Lainnya --</option>';
        
        // Normalkan bentuk data array dari server
        var arr = [];
        if (Array.isArray(res)) {
          arr = res;
        } else if (res && res.data && Array.isArray(res.data)) {
          arr = res.data;
        }

        if (arr && arr.length > 0) {
          var countAktif = 0;
          
          arr.forEach(function(s) {
            var idSekolah = s.id_sekolah || s.ID_Sekolah || s[0] || "";
            var namaSekolah = s.nama_sekolah || s.Nama_Sekolah || s[1] || "";
            var npsn = s.npsn || s.NPSN || s[2] || "";
            var statusDb = s.status || s.Status || s[5] || "";

            if (!idSekolah) return;

            // ELIMINASI: Singkirkan sekolah asal yang menolak siswa saat ini
            if (typeof sisSchId !== 'undefined' && idSekolah.toString().trim().toLowerCase() === sisSchId.toString().trim().toLowerCase()) {
              return; 
            }

            // Filter hanya sekolah yang aktif
            if (statusDb.toString().trim().toLowerCase() === "aktif" || statusDb === "") {
              var label = npsn ? namaSekolah + " (" + npsn + ")" : namaSekolah;
              sel.innerHTML += '<option value="' + idSekolah + '">' + label + '</option>';
              countAktif++;
            }
          });
          
          if (countAktif === 0) {
            sel.innerHTML = '<option value="" disabled>⚠️ Tidak ada sekolah alternatif yang aktif</option>';
          } else {
            console.log("✓ Sukses menginjeksikan " + countAktif + " opsi sekolah.");
          }
        } else {
          sel.innerHTML = '<option value="" disabled>⚠️ Gagal mengambil data / Database pusat kosong</option>';
        }
      })
      .withFailureHandler(function(err) {
        console.error("❌ EROR RESPOND SERVER:", err.message);
        
        // Kembalikan tombol ke kondisi normal jika putus koneksi
        if (btn) btn.disabled = false;
        if (icon) icon.classList.remove('d-none');
        if (spinner) spinner.classList.add('d-none');
        
        sel.innerHTML = '<option value="" disabled>❌ Gagal memuat data server: ' + err.message + '</option>';
      })
      .ambilSemuaSekolahMitra(); // 🌟 KUNCI: Panggil lurus fungsi server Anda yang sudah terbukti jalan!
  } else {
    if (btn) btn.disabled = false;
    if (icon) icon.classList.remove('d-none');
    if (spinner) spinner.classList.add('d-none');
    sel.innerHTML = '<option value="" disabled>❌ Jalur API Google Cloud tidak terdeteksi</option>';
  }
}

