function pindahSekolahPilihan() {
  var cabangBaru = document.getElementById('selSekolahAlternatif').value;
  if (!cabangBaru) { 
    alert("Pilih salah satu nama sekolah cabang alternatif."); 
    return; 
  }
  
  // Pastikan variabel global NISN dan ID Sekolah Asal tersedia
  var nisnAman = typeof sisNisnLogin !== 'undefined' ? sisNisnLogin : "";
  var sekolahLamaAman = typeof sisSchId !== 'undefined' ? sisSchId : "";

  if (!nisnAman || !sekolahLamaAman) {
    alert("❌ Sesi Bermasalah: NISN atau ID Sekolah asal tidak terdeteksi. Silakan muat ulang halaman.");
    return;
  }

  if (confirm("Apakah Anda yakin ingin memindahkan seluruh rekam berkas pendaftaran Anda ke cabang baru ini?\n\nSemua dokumen digital (KK, Akta, SKL, KIP) akan otomatis disalin ke database sekolah tujuan baru.")) {
    
    // 1. Kunci Tampilan dengan Animasi Loading agar user tidak klik berkali-kali
    var bBox = document.getElementById('boxStatusDitolak');
    var backupContent = bBox ? bBox.innerHTML : "";
    if (bBox) {
      bBox.innerHTML = "<div class='p-4 text-center text-dark'><div class='spinner-border text-primary me-2' role='status'></div><span class='fw-semibold'>Menghubungkan, menyalin berkas digital, & memindahkan basis data akun...</span></div>";
    }

    // 2. Jalankan jembatan API google.script.run
    if (typeof google !== 'undefined' && google.script && google.script.run) {
      google.script.run
        .withSuccessHandler(function(res) {
          if (res && res.status === "success") {
            // SUNTIKAN NOTIFIKASI SUKSES: Beri info transparan bahwa ID pendaftaran mereka juga diperbarui
            alert("✓ BERHASIL MUTASI!\n\nAkun pendaftaran dan seluruh dokumen digital Anda resmi dialihkan ke cabang tujuan baru.\n\nID Pendaftaran Baru Anda: " + res.new_id);
            
            // A. Update Variabel Global Sekolah Aktif Siswa di RAM Browser
            sisSchId = cabangBaru; 
            
            // B. Jika Anda menyimpan ID Registrasi di variabel global frontend, update juga di sini
            if (typeof sisIdPendaftar !== 'undefined') {
              sisIdPendaftar = res.new_id;
            }

            // C. Reset checkbox persetujuan syarat agar tertib administrasi di sekolah baru
            var chkSyarat = document.getElementById('chkPersetujuanSyarat');
            if (chkSyarat) {
              chkSyarat.checked = false;
            }
            
            // D. Jalankan fungsi pengecekan tombol simpan bawaan Anda
            if (typeof validasiKunciTombolSimpan === 'function') {
              validasiKunciTombolSimpan();
            }
            
            // E. Ambil data terbaru dari spreadsheet sekolah baru untuk di-render di dashboard siswa
            if (typeof muatDataSiswaDatabase === 'function') {
              muatDataSiswaDatabase();
            }

          } else {
            // Jika ditolak oleh backend (misal karena status aslinya bukan "Ditolak")
            alert("⚠️ Gagal beralih: " + (res.message || "Terjadi kendala saat memindahkan berkas."));
            if (bBox) bBox.innerHTML = backupContent;
          }
        })
        .withFailureHandler(function(err) {
          alert("❌ Crash Jaringan: Gagal menghubungi server cloud. " + err.toString());
          if (bBox) bBox.innerHTML = backupContent;
        })
        // 🔥 VALIDASI UTAMA: Kita tembak 3 parameter wajib sesuai urutan fungsi di Code.gs!
        // Urutan: (nisn, idSekolahLama, idSekolahBaru)
        .prosesPindahSekolahPilihanSiswa(nisnAman, sekolahLamaAman, cabangBaru);
        
    } else {
      alert("❌ Environment Error: API Google Apps Script tidak termuat sempurna.");
      if (bBox) bBox.innerHTML = backupContent;
    }
  }
}


function prosesSimpanBiodataSiswa(btn) {
  var jkTerpilih = "-";
  var rJk = document.getElementsByName("rb_jk");
  for (var i = 0; i < rJk.length; i++) { if (rJk[i].checked) { jkTerpilih = rJk[i].value; break; } }

  var jpTerpilih = "-";
  var rJp = document.getElementsByName("rb_jp");
  for (var i = 0; i < rJp.length; i++) { if (rJp[i].checked) { jpTerpilih = rJp[i].value; break; } }

  var txtAsli = btn.innerHTML; btn.disabled = true; btn.innerHTML = "Menyimpan...";

  var payload = {
    kontak: document.getElementById('formTelepon').value.trim(),
    nik_siswa: document.getElementById('formNIK').value.trim(),
    nama: document.getElementById('formNamaSiswa').value.trim().toUpperCase(),
    asal_sekolah: document.getElementById('f_asal').value.trim().toUpperCase(),
    tempat_lahir: document.getElementById('f_tempat_lahir').value.trim().toUpperCase(),
    tanggal_lahir: document.getElementById('f_tanggal_lahir').value,
    alamat: document.getElementById('f_alamat').value.trim().toUpperCase(),
    jenis_kelamin: jkTerpilih, jenis_pendaftaran: jpTerpilih,
    nama_ayah: document.getElementById('f_nama_ayah').value.trim().toUpperCase(),
    nik_ayah: document.getElementById('f_nik_ayah').value.trim(),
    nama_ibu: document.getElementById('f_nama_ibu').value.trim().toUpperCase(),
    nik_ibu: document.getElementById('f_nik_ibu').value.trim(),
    jumlah_saudara: document.getElementById('f_jumlah_saudara').value || "0",
    anak_ke: document.getElementById('f_anak_ke').value || "1",
    kelas_dimasuki: document.getElementById('f_kelas_dimasuki').value.trim().toUpperCase()
  };

  google.script.run
    .withSuccessHandler(function(res) {
      btn.disabled = false; btn.innerHTML = txtAsli;
      if (res && res.status === "success") {
        alert("✅ Berhasil! Formulir Dapodik Anda telah diperbarui dalam bentuk kapital murni.");
        document.getElementById('chkPersetujuanSyarat').checked = false;
        validasiKunciTombolSimpan();
        muatDataSiswaDatabase();
      } else { alert("❌ Gagal: " + res.message); }
    })
    .withFailureHandler(function(err) { btn.disabled = false; btn.innerHTML = txtAsli; alert("🚨 Error Jaringan."); })
    .updateBiodataSiswaServer(sisSchId, sisIdPendaftar, payload);
}

