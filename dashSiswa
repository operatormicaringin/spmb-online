<script>
// Penampung variabel global sesi login siswa
var sisNisnLogin = sisNisnLogin || "";
var sisSchId = sisSchId || "";
var sisIdPendaftar = "";

window.addEventListener('DOMContentLoaded', function() {
  muatDataSiswaDatabase();
});

/**
 * =========================================================================
 * 🔄 CORE FRONTEND ENGINE: SINKRONISASI DATABASES DASHBOARD SISWA (UTUH)
 * FIX: Auto-Kunci Kop Admin, Kebal Sandbox Foto Drive, & Sinkronisasi Cache Cetak
 * =========================================================================
 */
function muatDataSiswaDatabase() {
  console.log("Memulai sinkronisasi data profil lengkap siswa...");
  
  // -------------------------------------------------------------------------
  // TAHAP 1: VALIDASI & PRE-FETCH OVERRIDE LOCALSTORAGE STORAGE
  // -------------------------------------------------------------------------
  if (!sisSchId || !sisNisnLogin) {
    var sesiTersimpan = localStorage.getItem("spmb_sesi_user");
    if (sesiTersimpan) {
      var user = JSON.parse(sesiTersimpan);
      sisNisnLogin = user.username ? user.username.toString().trim() : "";
      sisSchId = user.id_sekolah ? user.id_sekolah.toString().trim() : "";
    }
  }

  if (!sisNisnLogin || !sisSchId) {
    console.error("❌ EROR SESI: ID Sekolah atau NISN login tidak ditemukan di localStorage.");
    alert("Sesi siswa telah habis atau tidak valid. Silakan lakukan login ulang.");
    if (typeof switchHalaman === "function") switchHalaman('landing-page');
    return;
  }

  // -------------------------------------------------------------------------
  // FITUR 1: SINKRONISASI BANNER AKTIF & KUNCI KOP SURAT ADMIN (INTEGRATED)
  // -------------------------------------------------------------------------
  if (sisSchId) {
    if (typeof google !== 'undefined' && google.script && google.script.run) {
      google.script.run
        .withSuccessHandler(function(res) {
          if (res && res.status === "success" && res.data) {
            var elTahun = document.getElementById('lblTahunPelajaran');
            var elKontak = document.getElementById('lblKontakAdmin');
            
            if (elTahun) elTahun.innerText = res.data.tahun_pelajaran || "";
            if (elKontak) elKontak.innerText = res.data.kontak_admin || "";
            
            // 🔥 LOCK SAKTI: Amankan kop surat dari admin sekolah ke memori global frontend
            if (typeof kopSuratDariAdminSekolah !== 'undefined') {
              kopSuratDariAdminSekolah = res.data.header_laporan || "";
              console.log("🏛️ Kop Surat resmi Admin berhasil diamankan di RAM browser.");
            }
          }
        })
        .ambilKonfigurasiSiswa(sisSchId); // Pastikan fungsi server ini me-return header_laporan
    }
  }

  // -------------------------------------------------------------------------
  // FITUR 2: SINKRONISASI NAMA SEKOLAH ASAL/TUJUAN DI BANNER UTAMA
  // -------------------------------------------------------------------------
  if (sisNisnLogin) {
    if (typeof google !== 'undefined' && google.script && google.script.run) {
      google.script.run
        .withSuccessHandler(function(namaSekolahPusat) {
          var elSekolah = document.getElementById('sisSekolahDisplay');
          if (elSekolah && namaSekolahPusat) {
            elSekolah.innerHTML = `<i class="bi bi-building-fill me-1">Sekolah Tujuan: </i><strong class="text-white bg-white bg-opacity-25 px-2 py-1 rounded shadow-sm">${namaSekolahPusat}</strong>`;
          }
        })
        .ambilNamaSekolahTujuanSiswa(sisNisnLogin);
    }
  }

  // -------------------------------------------------------------------------
  // EMBARKASI UTAMA: AMBIL BARIS DATA ISIAN FORMULIR & IDENTITAS PROFIL SISWA
  // -------------------------------------------------------------------------
  if (typeof google !== 'undefined' && google.script && google.script.run) {
    google.script.run
      .withSuccessHandler(function(res) {
        if (res && res.status === "success") {
          var d = res.data;
          if (!d) { 
            console.error("❌ EROR DATABASE: Respon server success tapi data objek siswa kosong."); 
            return; 
          }
          
          sisIdPendaftar = d.id_pendaftar; 
          
          // 🔥 CACHE SYNC: Masukkan data ke array cache lokal untuk amunisi fungsi tombol cetak SK Anda
          if (typeof cachePendaftarSekolahMitra !== 'undefined') {
            cachePendaftarSekolahMitra = [ d ];
          }
          
          // Pemetaan Teks Layar Dashboard Monitor
          if (document.getElementById('sisNamaDisplay')) document.getElementById('sisNamaDisplay').innerText = (d.nama || "").toUpperCase();
          if (document.getElementById('sisNisnDisplay')) document.getElementById('sisNisnDisplay').innerText = "ID REG: " + (sisIdPendaftar || "-") + " | NISN: " + (d.nisn || "-");
          
          // Pemetaan Input Value di Formulir Biodata Mandiri
          if (document.getElementById('formNamaSiswa')) document.getElementById('formNamaSiswa').value = (d.nama || "").toUpperCase();
          if (document.getElementById('formTelepon')) document.getElementById('formTelepon').value = d.kontak || "";
          if (document.getElementById('formNIK')) document.getElementById('formNIK').value = d.nik_siswa || "";
          if (document.getElementById('f_asal')) document.getElementById('f_asal').value = (d.asal_sekolah || "").toUpperCase();
          if (document.getElementById('f_alamat')) document.getElementById('f_alamat').value = (d.alamat || "").toUpperCase();
          if (document.getElementById('f_tempat_lahir')) document.getElementById('f_tempat_lahir').value = (d.tempat_lahir || "").toUpperCase();
          if (document.getElementById('f_tanggal_lahir')) document.getElementById('f_tanggal_lahir').value = d.tanggal_lahir || "";
          if (document.getElementById('f_nama_ayah')) document.getElementById('f_nama_ayah').value = (d.nama_ayah || "").toUpperCase();
          if (document.getElementById('f_nik_ayah')) document.getElementById('f_nik_ayah').value = d.nik_ayah || "";
          if (document.getElementById('f_nama_ibu')) document.getElementById('f_nama_ibu').value = (d.nama_ibu || "").toUpperCase();
          if (document.getElementById('f_nik_ibu')) document.getElementById('f_nik_ibu').value = d.nik_ibu || "";
          if (document.getElementById('f_jumlah_saudara')) document.getElementById('f_jumlah_saudara').value = d.jumlah_saudara || 0;
          if (document.getElementById('f_anak_ke')) document.getElementById('f_anak_ke').value = d.anak_ke || 1;
          if (document.getElementById('f_kelas_dimasuki')) document.getElementById('f_kelas_dimasuki').value = d.kelas_dimasuki || "";
          
          // 1. Set Radio Button Jenis Kelamin
          if (d.jenis_kelamin) {
            let rbJK = document.querySelector(`input[name="rb_jk"][value="${d.jenis_kelamin}"]`);
            if (rbJK) rbJK.checked = true;
          }

          // 2. Set Radio Button Jenis Pendaftaran
          if (d.jenis_pendaftaran) {
            let rbJP = document.querySelector(`input[name="rb_jp"][value="${d.jenis_pendaftaran}"]`);
            if (rbJP) rbJP.checked = true;
          }
          
