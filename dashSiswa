function uploadDokumenSiswa(input, jenisDokumen) {
  var file = input.files[0]; if (!file) return;
  if (file.size > 2 * 1024 * 1024) { alert("❌ Maksimal file sebesar 2MB."); input.value = ""; return; }

  var reader = new FileReader();
  reader.onload = function(e) {
    var badgeEl = document.getElementById('badge_' + jenisDokumen);
    if (badgeEl) {
      badgeEl.className = "badge text-xs mt-1 bg-warning-subtle text-warning border border-warning-subtle";
      badgeEl.innerHTML = `<span class="spinner-border spinner-border-xs me-1"></span>Mengunggah...`;
    }
    google.script.run
      .withSuccessHandler(function(res) {
        input.value = "";
        if (res && res.status === "success") { alert("✅ Dokumen " + jenisDokumen + " sukses diperbarui."); }
        muatDataSiswaDatabase();
      })
      .prosesUploadDokumenServer(sisSchId, sisIdPendaftar, jenisDokumen, e.target.result);
  };
  reader.readAsDataURL(file);
}

function uploadFotoProfil(input) {
  var file = input.files[0];
  if (!file) return;

  // 1. Validasi Ukuran File (Maksimal 2MB)
  if (file.size > 2 * 1024 * 1024) {
    alert("❌ Batas Ukuran File: Maksimal foto profil sebesar 2MB.");
    input.value = "";
    return;
  }

  var reader = new FileReader();
  reader.onload = function(e) {
    // 2. Validasi Ketersediaan Variabel Sesi
    if (typeof sisSchId === 'undefined' || typeof sisIdPendaftar === 'undefined') {
      alert("❌ Sesi Gagal: Parameter ID Instansi atau ID Siswa tidak ditemukan.");
      return;
    }

    var iconProfil = document.getElementById('iconFotoProfil');
    var imgProfil = document.getElementById('imgFotoProfil');
    
    // 3. MULAI ANIMASI LOADING
    if (imgProfil) imgProfil.classList.add('d-none');
    if (iconProfil) {
      iconProfil.className = "spinner-border text-primary";
      iconProfil.style.width = "3rem";
      iconProfil.style.height = "3rem";
      iconProfil.innerText = "";
      iconProfil.classList.remove('d-none');
    }

    input.disabled = true;

    // 4. KIRIM DATA KE SERVER
    google.script.run
      .withSuccessHandler(function(res) {
        input.disabled = false;
        input.value = ""; 

        if (res && res.status === "success") {
          alert("✅ Sukses! Foto profil Anda berhasil diperbarui.");
          
          // =====================================================================
          // DI SINI TEMPATNYA: PROSES REFRESH OTOMATIS INSTAN SETELAH UPLOAD SUKSES
          // =====================================================================
          if (res.link && res.link.includes("drive.google.com")) {
            var fileId = "";
            if (res.link.includes("/d/")) {
              fileId = res.link.split("/d/")[1].split("/")[0];
            } else if (res.link.includes("id=")) {
              fileId = res.link.split("id=")[1].split("&")[0];
            }
            
            if (fileId !== "") {
              // Mengubah url Drive menjadi direct link gambar
              var directImageUrl = "https://lh3.googleusercontent.com/u/0/d/" + fileId;
              
              if (imgProfil) {
                // KODE ANDA DI SINI: Memaksa browser bypass cache menggunakan timestamp (?t=)
                imgProfil.src = directImageUrl + "?t=" + new Date().getTime();
                imgProfil.classList.remove('d-none');
              }
              if (iconProfil) iconProfil.classList.add('d-none');
            }
          }
          // =====================================================================
          
          // Tetap panggil ini untuk memperbarui memori cache sistem di background
          muatDataSiswaDatabase(); 

        } else {
          alert("❌ Gagal unggah foto: " + (res.message || "Terjadi kesalahan sistem."));
          hentikanLoadingFotoSiswa(imgProfil, iconProfil);
        }
      })
      .withFailureHandler(function(err) {
        input.disabled = false;
        input.value = "";
        alert("🚨 Gangguan Jaringan: " + err.message);
        hentikanLoadingFotoSiswa(imgProfil, iconProfil);
      })
      .prosesUploadFotoProfilServer(sisSchId, sisIdPendaftar, e.target.result);
  };
  
  reader.readAsDataURL(file);
}

// Fungsi pembantu jika upload gagal agar spinner kembali jadi icon siluet
function hentikanLoadingFotoSiswa(img, icon) {
  if (img && img.src && img.src !== "") {
    img.classList.remove('d-none');
    if (icon) icon.classList.add('d-none');
  } else {
    if (img) img.classList.add('d-none');
    if (icon) {
      icon.className = "bi bi-person-circle text-secondary display-4";
      icon.style.width = "";
      icon.style.height = "";
    }
  }
}

function segarkanBerkasSiswa(btn) {
  var txt = btn.innerHTML; btn.disabled = true; btn.innerHTML = "<span class='spinner-border spinner-border-sm text-primary me-2'></span>...";
  muatDataSiswaDatabase();
  setTimeout(function() { btn.disabled = false; btn.innerHTML = txt; }, 1500);
}
